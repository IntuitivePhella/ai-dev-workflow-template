{
  "name": "ai-phellos",
  "version": "0.1.0",
  "description": "Operating system for disciplined, intent-adaptive AI software development with Codex, Claude Code, and markdown-aware coding agents.",
  "private": false,
  "type": "commonjs",
  "bin": {
    "aiwf": "scripts/aiwf.js"
  },
  "files": [
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE",
    "README.md",
    "README.pt-BR.md",
    "README.es.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "ai/",
    "!ai/_local/**",
    "docs/",
    "prompts/",
    "scripts/",
    ".claude/",
    ".codex/",
    ".github/pull_request_template.md"
  ],
  "scripts": {
    "aiwf": "node scripts/aiwf.js",
    "doctor": "node scripts/aiwf.js doctor",
    "gates": "node scripts/aiwf.js gates",
    "pack:dry-run": "npm pack --dry-run",
    "test": "node --test tests/*.test.js"
  },
  "keywords": [
    "ai",
    "workflow",
    "ai-phellos",
    "codex",
    "claude-code",
    "agents",
    "software-development",
    "tdd",
    "spec-driven-development",
    "intent-routing"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IntuitivePhella/AI-PhellOS.git"
  },
  "bugs": {
    "url": "https://github.com/IntuitivePhella/AI-PhellOS/issues"
  },
  "homepage": "https://github.com/IntuitivePhella/AI-PhellOS#readme"
}
