{
  "name": "ai-dev-workflow-template",
  "version": "0.1.0",
  "description": "Tool-agnostic AI development workflow for Codex, Claude Code, and Markdown-aware coding agents.",
  "private": false,
  "type": "commonjs",
  "bin": {
    "aiwf": "scripts/aiwf.js"
  },
  "files": [
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE",
    "README.md",
    "ai/",
    "docs/",
    "prompts/",
    "scripts/",
    ".claude/",
    ".codex/",
    ".github/pull_request_template.md"
  ],
  "scripts": {
    "aiwf": "node scripts/aiwf.js",
    "doctor": "node scripts/aiwf.js doctor",
    "gates": "node scripts/aiwf.js gates",
    "pack:dry-run": "npm pack --dry-run",
    "test": "node scripts/aiwf.js doctor"
  },
  "keywords": [
    "ai",
    "workflow",
    "codex",
    "claude-code",
    "agents",
    "software-development",
    "tdd",
    "spec-driven-development"
  ],
